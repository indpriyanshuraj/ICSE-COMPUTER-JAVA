# Handle line endings automatically for files detected as text
# and perform LF normalization.
* text=auto

# Explicitly set default line endings to LF (Linux/Unix style)
# to ensure consistency between Android/Termux and Windows.
* text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.pyc binary
