# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs.
# root = true tells EditorConfig not to look for files in parent directories.
root = true

[*]
# Use UTF-8 encoding for all files
charset = utf-8
# Use Unix-style line endings
end_of_line = lf
# Insert a newline at the end of every file
insert_final_newline = true
# Remove any whitespace characters before newline characters
trim_trailing_whitespace = true
# Use 4 spaces for indentation (Standard for Java)
indent_style = space
indent_size = 4

[*.{md,yml,json}]
# Use 2 spaces for Markdown, YAML, and JSON files
indent_size = 2

[*.{bat,cmd}]
# Use CRLF for Windows batch files
end_of_line = crlf
